# ── اجباری ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── اختیاری: JSearch ────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── اختیاری: AI Cover Letter ────────────────────────────────────────────────
# AI_PROVIDER: gemini | tokenlb | openai | custom
AI_PROVIDER=gemini
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gemini-2.0-flash
# AI_BASE_URL=https://api.openai.com/v1   # فقط برای custom
# 
# نمونه TokenLB:
# AI_PROVIDER=tokenlb
# AI_API_KEY=your_tokenlb_key
# AI_MODEL=claude-sonnet-4

# ── اختیاری: Telegraph (برای جلوگیری از بن شدن) ────────────────────────────
# اولین بار ربات خودش می‌سازه و تو لاگ چاپ می‌کنه — کپی کن اینجا
TELEGRAPH_TOKEN=your_telegraph_access_token_here

# ── اختیاری: Adzuna ─────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# ── اختیاری: Google Sheets ──────────────────────────────────────────────────
GSHEET_CREDENTIALS={"type":"service_account",...}
GSHEET_ID=your_google_sheet_id_here

# ── اختیاری: Cloudflare Worker ──────────────────────────────────────────────
CF_WORKER_URL=https://your-worker.workers.dev/jobs

# ── اختیاری: پروفایل کاربر (برای شخصی‌سازی Cover Letter) ────────────────────
# مهارت‌هات رو comma-separated بنویس — اگه خالی باشه، پیش‌فرض‌ها استفاده میشن
USER_SKILLS=python, wordpress, technical seo, ahrefs, semrush, google analytics
# یه خلاصه کوتاه از رزومه‌ات — AI ازش برای Cover Letter استفاده می‌کنه
USER_RESUME=SEO specialist with 2 years experience in technical SEO and content optimization
